# PayChat Backend Environment Variables

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Pine Labs UAT credentials
PINELABS_BASE_URL=https://uat.pinelabs.com
PINELABS_CLIENT_ID=your_pinelabs_client_id
PINELABS_CLIENT_SECRET=your_pinelabs_client_secret
PINELABS_MERCHANT_ID=your_pinelabs_merchant_id

# AWS Bedrock (for invoice OCR)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# App config
APP_BASE_URL=http://localhost:8000
DATABASE_URL=sqlite:///./paychat.db
INVOICES_DIR=/tmp/paychat_invoices
